# ── LLM Stack Configuration ──────────────────────────────────────────
# Target: Windows 11 / Docker Desktop (WSL2) / AMD RX 9070 XT (RDNA 4)

COMPOSE_PROJECT_NAME=llm-stack

# ── ROCm / AMD GPU ───────────────────────────────────────────────────
# CRITICAL: RDNA 4 (gfx1201) is not officially supported by ROCm.
# This override forces ROCm to treat it as gfx1100 (RDNA 3 / Navi 31).
HSA_OVERRIDE_GFX_VERSION=11.0.0

# ── Ollama ───────────────────────────────────────────────────────────
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# ── Open WebUI ───────────────────────────────────────────────────────
WEBUI_PORT=3000
WEBUI_AUTH=true

# ── Ouroboros Agent (future) ─────────────────────────────────────────
# OLLAMA_API_URL=http://localhost:11434/api
# OUROBOROS_MODEL=qwen2.5-coder:7b
