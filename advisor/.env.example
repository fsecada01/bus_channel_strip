# Copy this file to .env and fill in your values.
# The justfile loads .env automatically via `set dotenv-load := true`.

# Required: Anthropic API key for Claude suggestions
ANTHROPIC_API_KEY=sk-ant-...

# Optional: port (default 7373)
# BCS_ADVISOR_PORT=7373

# Optional: override profiles JSON path
# BCS_PROFILES_PATH=../docs/specs/studio-profiles.json
